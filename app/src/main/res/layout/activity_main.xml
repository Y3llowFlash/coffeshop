<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream"
    android:paddingStart="16dp"
    android:paddingTop="16dp"
    android:paddingEnd="16dp"
    android:paddingBottom="16dp">

    <TextView
        android:id="@+id/tvHeaderTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:text="Coffee Menu"
        android:textColor="@color/coffeeBrown"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/imgCart"
        app:layout_constraintEnd_toStartOf="@+id/imgMenuEditor"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/imgCart" />

    <ImageView
        android:id="@+id/imgMenuEditor"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_cart_icon"
        android:contentDescription="Open menu editor"
        android:padding="10dp"
        android:src="@android:drawable/ic_menu_edit"
        app:layout_constraintBottom_toBottomOf="@id/imgCart"
        app:layout_constraintEnd_toStartOf="@+id/imgCart"
        app:layout_constraintTop_toTopOf="@id/imgCart"
        app:tint="@color/coffeeBrown" />

    <ImageView
        android:id="@+id/imgCart"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/bg_cart_icon"
        android:contentDescription="Open cart"
        android:padding="10dp"
        android:src="@drawable/ic_cart"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/coffeeBrown" />

    <EditText
        android:id="@+id/etSearchCoffee"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_search_bar"
        android:drawablePadding="10dp"
        android:hint="Search your coffee"
        android:imeOptions="actionDone"
        android:inputType="text"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="@color/mochaText"
        android:textColorHint="@color/latte"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvHeaderTitle" />

    <HorizontalScrollView
        android:id="@+id/filterScrollView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:scrollbars="none"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/etSearchCoffee">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/filterChipGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingBottom="4dp"
            android:singleLine="true"
            app:chipSpacingHorizontal="8dp"
            app:chipSpacingVertical="4dp"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/btnFilterAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:gravity="center_vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:tag="all"
                android:text="All"
                android:textAllCaps="false"
                android:textColor="@color/filter_text_selector"
                android:textSize="14sp"
                android:textStyle="bold"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/filter_chip_background_selector"
                app:chipCornerRadius="16dp"
                app:chipIcon="@drawable/ic_filter_all"
                app:chipIconTint="@color/filter_text_color"
                app:chipMinHeight="44dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnFilterCoffee"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:gravity="center_vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:tag="coffee"
                android:text="Coffee"
                android:textAllCaps="false"
                android:textColor="@color/filter_text_selector"
                android:textSize="14sp"
                android:textStyle="bold"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/filter_chip_background_selector"
                app:chipCornerRadius="16dp"
                app:chipIcon="@drawable/ic_filter_coffee"
                app:chipIconTint="@color/filter_text_color"
                app:chipIconVisible="true"
                app:chipMinHeight="44dp"
                app:iconStartPadding="18dp"
                app:textStartPadding="6dp"
                app:textEndPadding="18dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnFilterNonCoffee"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:gravity="center_vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:tag="non_coffee"
                android:text="Non Coffee"
                android:textAllCaps="false"
                android:textColor="@color/filter_text_selector"
                android:textSize="14sp"
                android:textStyle="bold"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/filter_chip_background_selector"
                app:chipCornerRadius="16dp"
                app:chipIcon="@drawable/ic_filter_non_coffee"
                app:chipIconTint="@color/filter_text_color"
                app:chipIconVisible="true"
                app:chipMinHeight="44dp"
                app:iconStartPadding="18dp"
                app:textStartPadding="6dp"
                app:textEndPadding="18dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnFilterEats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:gravity="center_vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:tag="eats"
                android:text="Eats"
                android:textAllCaps="false"
                android:textColor="@color/filter_text_selector"
                android:textSize="14sp"
                android:textStyle="bold"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/filter_chip_background_selector"
                app:chipCornerRadius="16dp"
                app:chipIcon="@drawable/ic_filter_food"
                app:chipIconTint="@color/filter_text_color"
                app:chipIconVisible="true"
                app:chipMinHeight="44dp"
                app:iconStartPadding="18dp"
                app:textStartPadding="6dp"
                app:textEndPadding="18dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnFilterHot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:gravity="center_vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:tag="hot"
                android:text="Hot"
                android:textAllCaps="false"
                android:textColor="@color/filter_text_selector"
                android:textSize="14sp"
                android:textStyle="bold"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/filter_chip_background_selector"
                app:chipCornerRadius="16dp"
                app:chipIcon="@drawable/ic_filter_hot"
                app:chipIconTint="@color/filter_text_color"
                app:chipIconVisible="true"
                app:chipMinHeight="44dp"
                app:iconStartPadding="18dp"
                app:textStartPadding="6dp"
                app:textEndPadding="18dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnFilterIced"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:gravity="center_vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:tag="iced"
                android:text="Iced"
                android:textAllCaps="false"
                android:textColor="@color/filter_text_selector"
                android:textSize="14sp"
                android:textStyle="bold"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/filter_chip_background_selector"
                app:chipCornerRadius="16dp"
                app:chipIcon="@drawable/ic_filter_iced"
                app:chipIconTint="@color/filter_text_color"
                app:chipIconVisible="true"
                app:chipMinHeight="44dp"
                app:iconStartPadding="18dp"
                app:textStartPadding="6dp"
                app:textEndPadding="18dp" />
        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCoffeeList"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layout_constraintBottom_toTopOf="@id/btnViewCart"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/filterScrollView" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnViewCart"
        android:layout_width="wrap_content"
        android:layout_height="52dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="@color/coffeeBrown"
        android:elevation="8dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:minWidth="148dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:text="View Cart"
        android:textAllCaps="false"
        android:textColor="@color/cream"
        android:textSize="16sp"
        app:cornerRadius="26dp"
        app:icon="@drawable/ic_cart"
        app:iconGravity="textStart"
        app:iconPadding="8dp"
        app:iconTint="@color/cream"
        app:layout_constraintBottom_toTopOf="@id/footerButtons"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/footerButtons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:baselineAligned="false"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOrderHistory"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="12dp"
            android:layout_weight="1"
            android:backgroundTint="@color/latte"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="Order History"
            android:textAllCaps="false"
            android:textColor="@color/mochaText"
            android:textSize="15sp"
            app:cornerRadius="14dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAnalytics"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:backgroundTint="@color/latte"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="Sales Analytics"
            android:textAllCaps="false"
            android:textColor="@color/mochaText"
            android:textSize="15sp"
            app:cornerRadius="14dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
