<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_cart_row"
    android:elevation="2dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="16dp">

    <Button
        android:id="@+id/btnCartMinus"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/bg_quantity_minus"
        android:elevation="4dp"
        android:minWidth="0dp"
        android:text="-"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvCartQty"
        android:layout_width="52dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_qty_badge"
        android:gravity="center"
        android:text="1x"
        android:textColor="@color/coffeeBrown"
        android:textSize="16sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnCartPlus"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_quantity_plus"
        android:elevation="4dp"
        android:minWidth="0dp"
        android:text="+"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvCartName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:text="Coffee Name"
        android:textColor="@color/mochaText"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvCartPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="$0.00"
        android:textColor="@color/coffeeBrown"
        android:textSize="16sp"
        android:textStyle="bold" />

</LinearLayout>
